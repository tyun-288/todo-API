<!DOCTYPE html>
<html>
    <head>
        <meta charset="utf-8">
    <title>Mytask</title>
    <link rel="stylesheet" href="/style.css">
    
    </head>

    <body>
        <div class = "container">
            <header>
                <h1>MY TASKS</h1>
                <a href="/new"">+new</a>
                <div class="search">
                    <form action="/find" method="GET">
                        <input type="text" name="title" placeholder="title">
                        <input type="text" name="body" placeholder="contents">
                        <button type="submit">タイトルまたは内容で検索</button>
                    </form>
                    <form action="/find" method="GET">
                        <p>期日で検索</p>
                        <input type="date" name="from"> ~ <input type="date" name="to">
                        <button type="submit">検索</button>
                    </form>
                </div>
            </header>

            <div class="list">
                <div class="list-head">
                    <span class="topic1">Task name</span>
                    <span class="topic2">Due date</span>
                    <span class="topic3">Projets</span>
                    
                    
                </div>
               <div class="list-body">
                       <ul class="list-body">
                
                        <% todos.forEach((item) => { %>
                          <li>
                            <div class="item-data">
                              <span class="title-column"><%= item.title %></span>
                              <br>
                              <p>内容: <%= item.body %></p>
                              <p>期日: <%= item.due_date %></p>
                              <p>created at: <%= item.created_at %></p> 
                              <span class="created-date"><%= item.created_at %></span>
                              <div class="action">
                              <form action="/delete/<%= item.id %>" method="POST">
                                <button type="submit">削除</button>
                              </form>
                              <a href="/edit/<%=item.id%>">編集</a>
                              <form action="/clone/<%=item.id%>" method="GET">
                                <button type="submit">複製する</button>
                              </form>
                              <form action="/complete/<%= item.id %>" method="POST">
                                <input type="checkbox" onchange="this.form.submit()" <%= item.completed_at ? 'checked' : '' %> />
                              </form>
                              <p>completed at: <%= item.completed_at %></p>
                              
                              </div>
                            </div>
                          </li>
                        <% }); %>
                      </ul>
                    </div>
                </div>
        </div>

        
    </body>
</html>